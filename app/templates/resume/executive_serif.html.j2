<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{{ personal.full_name or resume_title }}</title>
  <style>
    @page { size: A4; margin: 14mm; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: #ffffff;
      color: #2f2923;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 10.6pt;
      line-height: 1.5;
    }
    .header {
      border-bottom: 1px solid #d8d0c5;
      padding-bottom: 18px;
      text-align: center;
    }
    .role {
      font-family: "Helvetica Neue", Arial, sans-serif;
      font-size: 9pt;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: #7d6d5a;
    }
    h1 {
      margin: 10px 0 0 0;
      font-size: 27pt;
      font-weight: 600;
      letter-spacing: 0.01em;
      color: #2f261d;
    }
    .contact, .links {
      margin-top: 9px;
      font-family: "Helvetica Neue", Arial, sans-serif;
      font-size: 8.8pt;
      color: #6b6258;
    }
    .contact span, .links span { margin: 0 8px; }
    h2 {
      margin: 22px 0 10px 0;
      padding-bottom: 4px;
      border-bottom: 1px solid #d8d0c5;
      font-family: "Helvetica Neue", Arial, sans-serif;
      font-size: 9.8pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.24em;
      color: #5f5447;
    }
    p { margin: 0; }
    .summary { color: #2d2924; }
    .item { margin-bottom: 16px; }
    .row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
    }
    .title {
      font-size: 11pt;
      font-weight: 700;
      color: #2f261d;
    }
    .meta, .dates {
      font-family: "Helvetica Neue", Arial, sans-serif;
      font-size: 8.9pt;
      color: #6b6258;
    }
    .dates {
      white-space: nowrap;
      font-weight: 700;
    }
    ul {
      margin: 7px 0 0 18px;
      padding: 0;
    }
    li { margin-bottom: 4px; }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 22px;
    }
    .skill-row { margin-bottom: 8px; }
    .skill-row strong {
      display: block;
      margin-bottom: 2px;
      font-family: "Helvetica Neue", Arial, sans-serif;
      font-size: 8.8pt;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: #2f261d;
    }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <header class="header">
    <div class="role">{{ resume_title }}</div>
    <h1>{{ personal.full_name }}</h1>
    {% if personal.contact_items %}
    <div class="contact">
      {% for item in personal.contact_items %}<span>{{ item }}</span>{% endfor %}
    </div>
    {% endif %}
    {% if personal.links %}
    <div class="links">
      {% for link in personal.links %}<span>{{ link.label }} {{ link.display }}</span>{% endfor %}
    </div>
    {% endif %}
  </header>

  {% if summary %}
  <section>
    <h2>Executive Summary</h2>
    <p class="summary">{{ summary }}</p>
  </section>
  {% endif %}

  {% if experiences %}
  <section>
    <h2>Experience</h2>
    {% for job in experiences %}
    <div class="item">
      <div class="row">
        <div>
          <div class="title">{{ job.job_title }}</div>
          <div class="meta">{{ job.company }}{% if job.location %} · {{ job.location }}{% endif %}</div>
        </div>
        <div class="dates">{{ job.date_range }}</div>
      </div>
      {% if job.bullets %}
      <ul>
        {% for bullet in job.bullets %}<li>{{ bullet }}</li>{% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  <div class="footer-grid">
    <section>
      {% if educations %}
      <h2>Education</h2>
      {% for edu in educations %}
      <div class="item">
        <div class="row">
          <div>
            <div class="title">{{ edu.degree }}{% if edu.field_of_study %}, {{ edu.field_of_study }}{% endif %}</div>
            <div class="meta">{{ edu.institution }}{% if edu.location %} · {{ edu.location }}{% endif %}</div>
            {% if edu.gpa %}<div class="meta">GPA {{ edu.gpa }}</div>{% endif %}
          </div>
          <div class="dates">{{ edu.date_range }}</div>
        </div>
        {% if edu.description %}<p class="summary" style="margin-top:6px;">{{ edu.description }}</p>{% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </section>

    <section>
      {% if skills %}
      <h2>Skills</h2>
      {% for skill in skills %}
      <div class="skill-row">
        <strong>{{ skill.category }}</strong>
        <div class="meta">{{ skill.items | join(' • ') }}</div>
      </div>
      {% endfor %}
      {% endif %}
    </section>
  </div>
</body>
</html>
