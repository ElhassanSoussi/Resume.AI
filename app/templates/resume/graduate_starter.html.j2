<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{{ personal.full_name or resume_title }}</title>
  <style>
    @page { size: A4; margin: 14mm; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: #ffffff;
      color: #1f2a38;
      font-family: "Helvetica Neue", Arial, sans-serif;
      font-size: 10.45pt;
      line-height: 1.48;
    }
    .accent {
      width: 74px;
      height: 6px;
      border-radius: 999px;
      background: #516f9f;
      margin-bottom: 16px;
    }
    .header {
      border-bottom: 1px solid #d7dfeb;
      padding-bottom: 17px;
    }
    h1 {
      margin: 0;
      font-size: 24pt;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #152132;
    }
    .role {
      margin-top: 6px;
      font-size: 9pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: #516f9f;
    }
    .contact, .links {
      margin-top: 8px;
      font-size: 8.8pt;
      color: #617186;
    }
    .contact span, .links span {
      margin-right: 12px;
    }
    h2 {
      margin: 18px 0 9px 0;
      padding-bottom: 4px;
      border-bottom: 1px solid #d7dfeb;
      font-size: 9.4pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: #516f9f;
    }
    p { margin: 0; }
    .summary { color: #334153; }
    .item { margin-bottom: 14px; }
    .row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
    }
    .title {
      font-size: 10.6pt;
      font-weight: 700;
      color: #152132;
    }
    .meta {
      margin-top: 2px;
      font-size: 9pt;
      color: #617186;
    }
    .dates {
      white-space: nowrap;
      font-size: 8.7pt;
      font-weight: 700;
      color: #5a6678;
    }
    ul {
      margin: 6px 0 0 18px;
      padding: 0;
    }
    li { margin-bottom: 4px; }
    .two-col {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
      gap: 22px;
    }
    .skill-row { margin-bottom: 8px; }
    .skill-row strong { color: #152132; }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <header class="header">
    <div class="accent"></div>
    <h1>{{ personal.full_name }}</h1>
    <div class="role">{{ resume_title }}</div>
    {% if personal.contact_items %}
    <div class="contact">
      {% for item in personal.contact_items %}<span>{{ item }}</span>{% endfor %}
    </div>
    {% endif %}
    {% if personal.links %}
    <div class="links">
      {% for link in personal.links %}<span>{{ link.label }} {{ link.display }}</span>{% endfor %}
    </div>
    {% endif %}
  </header>

  {% if summary %}
  <section>
    <h2>Profile</h2>
    <p class="summary">{{ summary }}</p>
  </section>
  {% endif %}

  <div class="two-col">
    <section>
      {% if educations %}
      <h2>Education</h2>
      {% for edu in educations %}
      <div class="item">
        <div class="row">
          <div>
            <div class="title">{{ edu.degree }}{% if edu.field_of_study %}, {{ edu.field_of_study }}{% endif %}</div>
            <div class="meta">{{ edu.institution }}{% if edu.location %} · {{ edu.location }}{% endif %}</div>
            {% if edu.gpa %}<div class="meta">GPA {{ edu.gpa }}</div>{% endif %}
          </div>
          <div class="dates">{{ edu.date_range }}</div>
        </div>
        {% if edu.description %}<p class="summary" style="margin-top:6px;">{{ edu.description }}</p>{% endif %}
      </div>
      {% endfor %}
      {% endif %}

      {% if skills %}
      <h2>Skills</h2>
      {% for skill in skills %}
      <div class="skill-row"><strong>{{ skill.category }}:</strong> {{ skill.items | join(' • ') }}</div>
      {% endfor %}
      {% endif %}
    </section>

    <section>
      {% if experiences %}
      <h2>Experience</h2>
      {% for job in experiences %}
      <div class="item">
        <div class="row">
          <div>
            <div class="title">{{ job.job_title }}</div>
            <div class="meta">{{ job.company }}{% if job.location %} · {{ job.location }}{% endif %}</div>
          </div>
          <div class="dates">{{ job.date_range }}</div>
        </div>
        {% if job.bullets %}
        <ul>
          {% for bullet in job.bullets %}<li>{{ bullet }}</li>{% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </section>
  </div>
</body>
</html>
