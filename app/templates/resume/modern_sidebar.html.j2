<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{{ personal.full_name or resume_title }}</title>
  <style>
    @page { size: A4; margin: 0; }
    * { box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      font-size: 10pt;
      line-height: 1.4;
      color: #0f172a;
      margin: 0;
    }
    .page {
      display: flex;
      min-height: 297mm;
    }
    aside {
      width: 30%;
      background: #0f172a;
      color: #f8fafc;
      padding: 18mm 10mm;
    }
    main {
      width: 70%;
      padding: 18mm 14mm;
      background: #fff;
    }
    .name {
      font-size: 20pt;
      font-weight: 700;
      line-height: 1.1;
      margin: 0 0 6px 0;
    }
    .role { font-size: 9.5pt; opacity: 0.85; margin-bottom: 16px; }
    .side-block { margin-bottom: 18px; }
    .side-block h3 {
      font-size: 9pt;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      border-bottom: 1px solid rgba(248,250,252,0.25);
      padding-bottom: 6px;
      margin: 0 0 8px 0;
    }
    .side-line { font-size: 8.8pt; margin-bottom: 5px; word-break: break-word; }
    .side-line a { color: #e2e8f0; text-decoration: none; }
    h2 {
      font-size: 11pt;
      color: #0f172a;
      border-left: 4px solid #2563eb;
      padding-left: 10px;
      margin: 0 0 10px 0;
    }
    .summary { font-size: 10pt; color: #334155; margin-bottom: 16px; }
    .job { margin-bottom: 14px; }
    .job-top { display: flex; justify-content: space-between; gap: 6px; }
    .jt { font-weight: 700; font-size: 10.5pt; }
    .co { font-size: 9.8pt; color: #475569; }
    .when { font-size: 8.8pt; color: #64748b; white-space: nowrap; }
    ul { margin: 5px 0 0 16px; padding: 0; }
    li { margin-bottom: 2px; }
    .edu-line { margin-bottom: 8px; }
    .skill-pill {
      display: inline-block;
      background: #1e293b;
      color: #e2e8f0;
      font-size: 8.5pt;
      padding: 3px 8px;
      border-radius: 4px;
      margin: 0 4px 4px 0;
    }
  </style>
</head>
<body>
  <div class="page">
    <aside>
      <div class="name">{{ personal.full_name }}</div>
      <div class="role">{{ resume_title }}</div>

      <div class="side-block">
        <h3>Contact</h3>
        {% if personal.email %}<div class="side-line">{{ personal.email }}</div>{% endif %}
        {% if personal.phone %}<div class="side-line">{{ personal.phone }}</div>{% endif %}
        {% if personal.location %}<div class="side-line">{{ personal.location }}</div>{% endif %}
        {% if personal.website %}<div class="side-line"><a href="{{ personal.website }}">{{ personal.website }}</a></div>{% endif %}
        {% if personal.linkedin_url %}<div class="side-line"><a href="{{ personal.linkedin_url }}">LinkedIn</a></div>{% endif %}
        {% if personal.github_url %}<div class="side-line"><a href="{{ personal.github_url }}">GitHub</a></div>{% endif %}
      </div>

      {% if skills %}
      <div class="side-block">
        <h3>Skills</h3>
        {% for sk in skills %}
          {% for item in sk.items %}
          <span class="skill-pill">{{ item }}</span>
          {% endfor %}
        {% endfor %}
      </div>
      {% endif %}

      {% if educations %}
      <div class="side-block">
        <h3>Education</h3>
        {% for edu in educations %}
        <div class="side-line" style="margin-bottom:10px;">
          <strong>{{ edu.institution }}</strong><br/>
          {{ edu.degree }}{% if edu.field_of_study %} · {{ edu.field_of_study }}{% endif %}<br/>
          <span style="opacity:0.8">{{ edu.date_range }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </aside>

    <main>
      {% if summary %}
      <h2>Profile</h2>
      <p class="summary">{{ summary }}</p>
      {% endif %}

      {% if experiences %}
      <h2>Experience</h2>
      {% for job in experiences %}
      <div class="job">
        <div class="job-top">
          <div>
            <div class="jt">{{ job.job_title }}</div>
            <div class="co">{{ job.company }}{% if job.location %} · {{ job.location }}{% endif %}</div>
          </div>
          <div class="when">{{ job.date_range }}</div>
        </div>
        {% if job.bullets %}
        <ul>
          {% for b in job.bullets %}<li>{{ b }}</li>{% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
      {% endif %}

      {% if skills %}
      <h2>Expertise</h2>
      {% for sk in skills %}
      <div class="edu-line">
        <strong>{{ sk.category }}:</strong>
        {{ sk.items | join(', ') }}
      </div>
      {% endfor %}
      {% endif %}
    </main>
  </div>
</body>
</html>
