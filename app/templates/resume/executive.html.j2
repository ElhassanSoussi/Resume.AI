<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{{ personal.full_name or resume_title }}</title>
  <style>
    @page { size: A4; margin: 12mm; }
    * { box-sizing: border-box; }
    body {
      font-family: Georgia, "Times New Roman", serif;
      font-size: 10.5pt;
      line-height: 1.42;
      color: #1c1917;
      margin: 0;
    }
    .banner {
      background: linear-gradient(135deg, #1c1917 0%, #44403c 100%);
      color: #fafaf9;
      padding: 16px 18px;
      margin-bottom: 14px;
    }
    .banner h1 {
      font-size: 24pt;
      font-weight: 400;
      margin: 0 0 6px 0;
      letter-spacing: 0.02em;
    }
    .banner .sub {
      font-size: 10pt;
      opacity: 0.92;
      font-family: system-ui, sans-serif;
    }
    .banner .contact {
      margin-top: 10px;
      font-family: system-ui, sans-serif;
      font-size: 8.8pt;
      opacity: 0.9;
    }
    .banner .contact span { margin-right: 14px; }
    .columns {
      display: flex;
      gap: 16px;
    }
    .col-left { width: 38%; }
    .col-right { width: 62%; }
    h2 {
      font-family: system-ui, sans-serif;
      font-size: 9.5pt;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: #78716c;
      margin: 16px 0 8px 0;
      border-bottom: 1px solid #d6d3d1;
      padding-bottom: 4px;
    }
    h2:first-child { margin-top: 0; }
    .summary {
      font-size: 10.5pt;
      color: #292524;
    }
    .job { margin-bottom: 12px; }
    .jh { display: flex; justify-content: space-between; gap: 8px; font-family: system-ui, sans-serif; }
    .title { font-weight: 700; font-size: 10.5pt; color: #1c1917; }
    .meta { font-size: 9pt; color: #57534e; }
    .dates { font-size: 8.8pt; color: #78716c; white-space: nowrap; }
    ul { margin: 4px 0 0 18px; padding: 0; }
    li { margin-bottom: 3px; }
    .edu { margin-bottom: 8px; font-family: system-ui, sans-serif; font-size: 9.5pt; }
    .skill-line { margin-bottom: 5px; font-family: system-ui, sans-serif; font-size: 9.5pt; }
    .skill-line strong { color: #44403c; }
  </style>
</head>
<body>
  <header class="banner">
    <h1>{{ personal.full_name }}</h1>
    <div class="sub">{{ resume_title }}</div>
    <div class="contact">
      {% if personal.email %}<span>{{ personal.email }}</span>{% endif %}
      {% if personal.phone %}<span>{{ personal.phone }}</span>{% endif %}
      {% if personal.location %}<span>{{ personal.location }}</span>{% endif %}
      {% if personal.website %}<span>{{ personal.website }}</span>{% endif %}
    </div>
  </header>

  <div class="columns">
    <div class="col-left">
      {% if skills %}
      <h2>Core competencies</h2>
      {% for sk in skills %}
      <div class="skill-line"><strong>{{ sk.category }}</strong><br/>{{ sk.items | join(' · ') }}</div>
      {% endfor %}
      {% endif %}

      {% if educations %}
      <h2>Education</h2>
      {% for edu in educations %}
      <div class="edu">
        <strong>{{ edu.institution }}</strong><br/>
        {{ edu.degree }}{% if edu.field_of_study %}, {{ edu.field_of_study }}{% endif %}<br/>
        <span style="color:#78716c">{{ edu.date_range }}</span>
        {% if edu.gpa %}<br/>GPA {{ edu.gpa }}{% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </div>

    <div class="col-right">
      {% if summary %}
      <h2>Executive summary</h2>
      <p class="summary">{{ summary }}</p>
      {% endif %}

      {% if experiences %}
      <h2>Leadership &amp; experience</h2>
      {% for job in experiences %}
      <div class="job">
        <div class="jh">
          <div>
            <div class="title">{{ job.job_title }}</div>
            <div class="meta">{{ job.company }}{% if job.location %} · {{ job.location }}{% endif %}</div>
          </div>
          <div class="dates">{{ job.date_range }}</div>
        </div>
        {% if job.bullets %}
        <ul>
          {% for b in job.bullets %}<li>{{ b }}</li>{% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </div>
  </div>
</body>
</html>
