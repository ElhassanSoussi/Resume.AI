<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{{ personal.full_name or resume_title }}</title>
  <style>
    @page { size: A4; margin: 14mm; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: #ffffff;
      color: #18222f;
      font-family: "Helvetica Neue", Arial, sans-serif;
      font-size: 10.5pt;
      line-height: 1.5;
    }
    .accent {
      width: 58px;
      height: 7px;
      border-radius: 999px;
      background: #1f4d8f;
      margin-bottom: 18px;
    }
    .header {
      border-bottom: 1px solid #d4ddea;
      padding-bottom: 18px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 220px;
      gap: 18px;
    }
    h1 {
      margin: 6px 0 0 0;
      font-size: 25pt;
      font-weight: 700;
      letter-spacing: -0.04em;
      color: #102033;
    }
    .role {
      font-size: 9.1pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #3562a8;
    }
    .contact, .links {
      font-size: 8.8pt;
      color: #556274;
      text-align: right;
    }
    .links { margin-top: 6px; }
    .links div { margin-top: 2px; }
    h2 {
      margin: 22px 0 10px 0;
      padding-bottom: 4px;
      border-bottom: 1px solid #c7d5ea;
      font-size: 10pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #1f4d8f;
    }
    p { margin: 0; }
    .summary { color: #27303a; }
    .item { margin-bottom: 16px; }
    .row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
    }
    .title {
      font-size: 10.8pt;
      font-weight: 700;
      color: #102033;
    }
    .meta {
      margin-top: 2px;
      font-size: 9.2pt;
      color: #556274;
    }
    .dates {
      white-space: nowrap;
      font-size: 8.9pt;
      font-weight: 700;
      color: #556274;
    }
    ul {
      margin: 7px 0 0 18px;
      padding: 0;
    }
    li { margin-bottom: 4px; }
    .skill-row { margin-bottom: 8px; }
    .skill-row strong { color: #102033; }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <div class="accent"></div>
  <header class="header">
    <div>
      <div class="role">{{ resume_title }}</div>
      <h1>{{ personal.full_name }}</h1>
    </div>
    <div>
      {% if personal.contact_items %}
      <div class="contact">
        {% for item in personal.contact_items %}<div>{{ item }}</div>{% endfor %}
      </div>
      {% endif %}
      {% if personal.links %}
      <div class="links">
        {% for link in personal.links %}<div>{{ link.label }} · {{ link.display }}</div>{% endfor %}
      </div>
      {% endif %}
    </div>
  </header>

  {% if summary %}
  <section>
    <h2>Summary</h2>
    <p class="summary">{{ summary }}</p>
  </section>
  {% endif %}

  {% if experiences %}
  <section>
    <h2>Experience</h2>
    {% for job in experiences %}
    <div class="item">
      <div class="row">
        <div>
          <div class="title">{{ job.job_title }}</div>
          <div class="meta">{{ job.company }}{% if job.location %} · {{ job.location }}{% endif %}</div>
        </div>
        <div class="dates">{{ job.date_range }}</div>
      </div>
      {% if job.bullets %}
      <ul>
        {% for bullet in job.bullets %}<li>{{ bullet }}</li>{% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if educations %}
  <section>
    <h2>Education</h2>
    {% for edu in educations %}
    <div class="item">
      <div class="row">
        <div>
          <div class="title">{{ edu.degree }}{% if edu.field_of_study %}, {{ edu.field_of_study }}{% endif %}</div>
          <div class="meta">{{ edu.institution }}{% if edu.location %} · {{ edu.location }}{% endif %}</div>
          {% if edu.gpa %}<div class="meta">GPA {{ edu.gpa }}</div>{% endif %}
        </div>
        <div class="dates">{{ edu.date_range }}</div>
      </div>
      {% if edu.description %}<p class="summary" style="margin-top:6px;">{{ edu.description }}</p>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if skills %}
  <section>
    <h2>Skills</h2>
    {% for skill in skills %}
    <div class="skill-row"><strong>{{ skill.category }}:</strong> {{ skill.items | join(' • ') }}</div>
    {% endfor %}
  </section>
  {% endif %}
</body>
</html>
