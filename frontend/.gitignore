# Repository-wide rules live in the parent `.gitignore`.
# Paths below are relative to `frontend/` (Next.js scaffold compatibility).

/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/.next/
/out/
/build
.vercel

/coverage

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
