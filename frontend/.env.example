# ── Local dev (default) ─────────────────────────────────────────
# Supabase Auth / session cookies
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Or use one of these aliases instead:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key
# NEXT_PUBLIC_SUPABASE_KEY=your-public-anon-key

# Leave NEXT_PUBLIC_API_URL unset so the app uses same-origin /api/v1 and Next.js
# proxies to FastAPI (see next.config.ts). Works for localhost and 127.0.0.1.

# Where the proxy forwards (your uvicorn host:port, no /api/v1 suffix):
# API_PROXY_TARGET=http://127.0.0.1:8000

# Server-side fetches only (RSC); defaults to http://127.0.0.1:8000/api/v1
# API_INTERNAL_BASE_URL=http://127.0.0.1:8000/api/v1

# ── Production / split deploy ─────────────────────────────────
# Option A: browser calls backend directly (configure CORS there).
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
# Example: NEXT_PUBLIC_API_URL=https://resume-api.onrender.com/api/v1

# Option B: keep browser calls same-origin and let Next proxy to your backend.
# API_PROXY_TARGET=https://resume-api.onrender.com

# Optional absolute app URL for server-side links. Browser checkout return URLs
# already fall back to window.location.origin on the current page.
# NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# Optional: shown on /support
# NEXT_PUBLIC_SUPPORT_EMAIL=you@yourdomain.com

# Optional: POST JSON { event, properties, ts, path } for funnel events (see ANALYTICS.md).
# NEXT_PUBLIC_ANALYTICS_WEBHOOK_URL=https://your-worker.example.com/rf-analytics

# Optional: closed beta — structured feedback form URL (Settings shows a button).
# NEXT_PUBLIC_BETA_FEEDBACK_URL=https://forms.gle/your-form-or-typeform
