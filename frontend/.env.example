# ── Local dev (default) ─────────────────────────────────────────
# Leave NEXT_PUBLIC_API_URL unset so the app uses same-origin /api/v1 and Next.js
# proxies to FastAPI (see next.config.ts). Works for localhost and 127.0.0.1.

# Where the proxy forwards (your uvicorn host:port, no /api/v1 suffix):
# API_PROXY_TARGET=http://127.0.0.1:8001

# Server-side fetches only (RSC); defaults to http://127.0.0.1:8001/api/v1
# API_INTERNAL_BASE_URL=http://127.0.0.1:8001/api/v1

# ── Production / split deploy ─────────────────────────────────
# Set when the browser must call the API on another origin (configure CORS there).
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Optional absolute app URL for server-side links (Stripe return URLs, etc.)
# NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
