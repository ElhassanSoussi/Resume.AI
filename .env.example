# ── Application ──────────────────────────────────────────
APP_NAME=ResumeForge AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database (Postgres — async SQLAlchemy / asyncpg) ───────
# Use a normal Postgres URL here. Do NOT use Neon “Data API” / PostgREST URLs
# (…/rest/v1) — those are HTTP; this app speaks Postgres over TCP.
#
# Neon (SQL editor → “connection string”): copy the `postgresql://…` string, then:
#   1. Change the scheme to  postgresql+asyncpg://
#   2. Keep host, user, password, db name; port 5432 if omitted
#   3. Use ssl query param, e.g.  ?ssl=require  (drop channel_binding if connect fails)
#
# Example shape (replace user, password, host, db):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech:5432/neondb?ssl=require
#
# Supabase:
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://neondb_owner:npg_8ZHgC7pPADIc@ep-bitter-lab-ajasw8ck-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_ECHO=false

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-256-bit-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenAI-compatible AI Provider ────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=3
AI_RETRY_BACKOFF_BASE_SECONDS=0.5
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS_SUMMARY=800
AI_MAX_OUTPUT_TOKENS_EXPERIENCE=1200
AI_MAX_OUTPUT_TOKENS_OPTIMIZE=4096

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_SINGLE_EXPORT=price_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# Webhook URL (Dashboard): POST {PUBLIC_API_BASE}/api/v1/payments/webhook

# ── Storage ──────────────────────────────────────────────
STORAGE_BUCKET=resumes

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
